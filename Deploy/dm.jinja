{% set ZONE = 'australia-southeast1-c' %}
{% set PROJECT = 'shipreq-dev' %}
{% set MACHINE_TYPE = 'f1-micro' %}

resources:
- name: taskman-cluster
  type: container.v1.cluster
  properties:
    zone: {{ ZONE }}
    cluster:
      name: taskman-cluster
      initialNodeCount: 1
      nodeConfig:
        machineType: https://www.googleapis.com/compute/v1/projects/{{PROJECT}}/zones/{{ZONE}}/machineTypes/{{MACHINE_TYPE}}
        oauthScopes:
        - https://www.googleapis.com/auth/devstorage.read_only # Container registry access
        - https://www.googleapis.com/auth/logging.write
        - https://www.googleapis.com/auth/monitoring
        preemptible: true
