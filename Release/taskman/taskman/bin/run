#!/bin/bash

cd $(dirname $(readlink -e "$0"))/.. || exit 1

[ $# -lt 1 ] && echo "Usage: $0 <main-class>" && exit 1

main="$1"; shift
resources=resources
uber=lib/taskman.jar
[ ! -e "$uber" ] && echo "Taskman JAR not found: $(pwd)/$uber" && exit 1
cp="$resources/.:$uber"

java_opt=(-cp "$cp" -Xmx28m -Drun.mode=production)
if [ -z "$client" ]; then
  java_opt+=(-server -Xms20m)
else
  java_opt+=(-client)
fi

exec java $JAVA_OPTS "${java_opt[@]}" $main "$@"
