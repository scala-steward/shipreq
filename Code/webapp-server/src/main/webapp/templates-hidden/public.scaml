!!! 5
%html(lang="en")
  %head
    -# %div(data-lift="embed?what=headers") TODO These headers should be shared with blank.scaml
    %meta(http-equiv="content-type" content="text/html; charset=UTF-8")
    %meta(name="viewport" content="width=device-width, initial-scale=1.0")
    %link(data-lift="Assets.favicon")
    <title data-lift="Menu.title"></title>

  %body#ly-default
    #ly-hdrbody
      .ly-content

        %header
          .loginInfo
            %div(data-lift="Authenticated")
              Logged in as <b>@<span data-lift="LoggedInUser.username"></span></b>.
              %a(data-lift="PageLink.logout")

            %div(data-lift="Authenticated.not")
              %a(data-lift="PageLink.home")
              |
              %a(data-lift="PageLink.login")
              |
              %a(data-lift="PageLink.register1")

          %section#notices(data-lift="Notices")

        #content CONTENT GOES HERE

      #ly-footer-push
    %footer#ly-footer
      .ly-content
        &copy; 2013-2014 Bearded Logic
        | <a data-lift="PageLink.about"></a>
        | <a data-lift="PageLink.tos"></a>
        | <a data-lift="PageLink.privacy"></a>
