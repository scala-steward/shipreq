#!/bin/bash

cd "$(dirname "$(readlink -e "$0")")/../docker" || exit 1

if [ $# -eq 0 ]; then
  self="$0"
  echo "Usage:"
  echo "  $self <env> [docker-compose-args...]"
  echo "Examples:"
  echo "  $self test up -d"
  echo "  $self dev up"
  exit 1
fi

env="$1"
shift

[ ! -e "$env" ] && echo "File not found: $(pwd)/$env" && exit 2
cd "$env"

# In project name (-p) dashes and underscores and removed automatically
exec docker-compose \
  -p shipreq$env \
  "$@"
