  80[label="3.E.3.a" tooltip="A indicates she wants to revoke the invitation"]
  81[label="3.E.3.b" tooltip="System revokes the invitation"]
  82[label="3.E.3.c" tooltip="A can see the invitation is `revoked` and not `accepted`"]
  83[label="3.E.4" tooltip="B changes his mind"]
  84[label="3.E.4.a" tooltip="B clicks `decline` on the invitation"]
