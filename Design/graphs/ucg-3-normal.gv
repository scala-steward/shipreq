  73[label="3.0.4.a" tooltip="Either: A types in B's username"]
  74[label="3.0.4.b" tooltip="Or if coming in from [3.1], A selects B from their \"address book\""]
  62[label="3.0.5" tooltip="System confirms that B's username is indeed belongs to an active user"]
  63[label="3.0.6" tooltip="A sets the permissions (which is either admin or collaborator at this point)"]
  64[label="3.0.7" tooltip="A hits `Invite`"]
  65[label="3.0.8" tooltip="System creates an invitation for B to join P"]
  66[label="3.0.9" tooltip="A can see a pending invite exists"]
