  }
  {node[fillcolor=skyblue style=filled shape=invhouse]
  70[label="3.1" tooltip="A & B have interacted before"]
  }
  {node[fillcolor=skyblue style="filled,rounded" shape=box]
  71[label="3.1.1" tooltip="They are in each other's \"address book\""]
  72[label="3.1.2" tooltip="Process begins"]
