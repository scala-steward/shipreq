    %section(style="padding-top:6rem")
      Must:
      %ul
        %li indicate which view is the default (has star)
        %li indicate which view is currently selected (orange and left-most)
        %li indicate whether the view is clean/dirty
        %li handle overflow
      Should:
      %ul
        %li changing view selection shouldn't affect layout
        %li views should be ordered automatically and predicably (i.e. A-Z, maybe default at head)
      %ul
        %li font & line colour (clear once, doesn't affect layout)
        %li(style="color:#bbb") background colour (clear once, doesn't affect layout, looks shit visually noise and inconsistent)
        %li icon (clear once, affects layout)
        %li(style="color:#bbb") style (bold/italics) (even once probably too subtle, affects layout)
        %li(style="color:#bbb") prefix/suffix char/text (text might be clear, affects layout)
      Problems/Ideas:
      %ul
        %li bar extending to FilterDeadButton might be confusing (purpose conflation)
        %li(style="color:#bbb") Maybe just show Unsaved + 3 MRU in top bar, button to expand/collapse section underneath with all views A-Z ← NO, just use flex-wrap
        %li(style="color:#bbb") SavedDirty: one or two items? ← 1. Everything A-Z, "Unsaved view" item {,dis}appearing and selection changing = too much change

      %div(style="min-height:20rem")
        .ui.simple.dropdown
          simple.dropdown
          .menu
            .item
              %i.icon.star
              Set as default
            .item
              %i.icon.write
              Rename...
            .item
              %i.icon.copy
              Save as...
            .item
              %i.icon.trash
              Delete
        .ui.compact.menu
          .ui.simple.dropdown.item
            compact.menu
            .menu
              .item
                %i.icon.star
                Set as default
              .item
                %i.icon.write
                Rename...
              .item
                %i.icon.copy
                Save as...
              .item
                %i.icon.trash
                Delete
        .ui.compact.selection.dropdown
          .text compact.selection.dropdown (needs JS)
          .menu
            .item
              %i.icon.star
              Set as default
            .item
              %i.icon.write
              Rename...
            .item
              %i.icon.copy
              Save as...
            .item
              %i.icon.trash
              Delete

  :javascript
    const times=(n,f)=>{while(n-->0)f();};

    times(5, () => $('#overflow-eg1 .ui').clone().appendTo('#overflow-eg1'));

    times(20, () => $('#other').clone().appendTo('#overflow-eg0 > *'));
    $('#FilterDeadButton').clone().appendTo('#overflow-eg0 > *');
    $('#overflow-eg0 > * > .item').click(function(e){
      $('#overflow-eg0 > * > .item').removeClass('orange').removeClass('active-hack');
      $(e.target).addClass('orange').addClass('active-hack');
    });

    // 400 feels a bit too fast in the overflow example
    $('.ui.dropdown.onhover').dropdown({on:"hover", delay: { show: 500 }});
    $('.ui.has-popup').popup({delay: { show: 400, hide: 0 }});
